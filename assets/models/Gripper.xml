<mujoco>
    <default>
        <default class="geom">
            <geom friction="1 0.5 0.5" contype="1" conaffinity="1" />
        </default>
        <default class="joint">
            <joint damping="2" />
        </default>
    </default>

    <worldbody>
        <body name="Gripper" pos="0 0 0">
            <!-- Rigid palm block attached to the wrist chain. -->
            <geom type="box" pos="0 0 0" size="0.01 0.01 0.01" rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0" />

            <body name="left_finger" pos="0 -0.02 0">
                <!-- Left jaw: single translational DOF along local +Y. -->
                <joint name="left_slide" type="slide" axis="0 1 0" range="-0.02 0.0" />
                <geom type="box" size="0.005 0.02 0.02" pos="0 0 0" rgba="0.2 0.2 0.2 1" />
            </body>

            <body name="right_finger" pos="0 0.02 0">
                <!-- Right jaw: mirrored slide axis for parallel closing motion. -->
                <joint name="right_slide" type="slide" axis="0 -1 0" range="-0.02 0.0" />
                <geom type="box" size="0.005 0.02 0.02" pos="0 0 0" rgba="0.2 0.2 0.2 1" />
            </body>
        </body>
    </worldbody>

    <actuator>
        <position joint="left_slide" name="left_slide_ctrl" kp="100" ctrlrange="-0.02 0.0" />
        <position joint="right_slide" name="right_slide_ctrl" kp="100" ctrlrange="-0.02 0.0" />
    </actuator>
</mujoco>
